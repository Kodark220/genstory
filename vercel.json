{
  "framework": "vite",
  "outputDirectory": "story-dashboard/dist",
  "rewrites": [
    {
      "source": "/api/rpc-bradbury/(.*)",
      "destination": "https://rpc-bradbury.genlayer.com/$1"
    },
    {
      "source": "/api/studio/(.*)",
      "destination": "https://studio.genlayer.com/api/$1"
    }
  ]
}
