{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/api/rpc-bradbury/(.*)",
      "destination": "https://rpc-bradbury.genlayer.com/$1"
    },
    {
      "source": "/api/studio/(.*)",
      "destination": "https://studio.genlayer.com/api/$1"
    }
  ]
}
